<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.moltbot.llm-wiki-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/moltbot/miniconda3/bin/python3</string>
        <string>/Users/moltbot/projects/llm-wiki/scripts/watch_input_pdfs.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/moltbot/projects/llm-wiki</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>ANTHROPIC_API_KEY</key>
        <string>YOUR_API_KEY_HERE</string>
        <key>LLM_WIKI_ROOT</key>
        <string>/Users/moltbot/projects/llm-wiki</string>
        <key>PATH</key>
        <string>/Users/moltbot/miniconda3/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/moltbot/projects/llm-wiki/logs/watcher.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/moltbot/projects/llm-wiki/logs/watcher_error.log</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
